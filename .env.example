# 复制为 .env.local 并填入真实值。`.env*` 已在 .gitignore 里。

# ------ Postgres ------
# 本地:用 docker compose up -d 起一个,默认连接串如下
# 生产:任意 Postgres 16+ 服务(Neon / Supabase / RDS / DO / 自托管 / etc.)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_fifa

# ------ OpenRouter ------
# https://openrouter.ai/keys 创建
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_SITE_URL=http://localhost:3000
# 注意:HTTP header 必须 ASCII。中文标题会被过滤,用英文。
OPENROUTER_SITE_TITLE=AI FIFA Predictor

# ------ Cron 鉴权 ------
# 任意 scheduler(Vercel Cron / GitHub Actions / 自家 cron)调端点时带:
#   Authorization: Bearer <CRON_SECRET>
# 本地随便填一个字符串
# 生产用 openssl rand -hex 32 生成
CRON_SECRET=local-dev-secret
